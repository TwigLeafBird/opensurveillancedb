[Unit]
Description=OpenSurveillanceDB UI (Docker)
Requires=docker.service
After=docker.service network-online.target
Wants=network-online.target

[Service]
User=osdb
Group=osdb
Restart=always
RestartSec=5
TimeoutStartSec=0

ExecStart=/usr/bin/docker run --rm --name opensurveillancedb-ui --publish 8080:80 --restart=no twigleafbird/opensurveillancedb-ui:latest
ExecStop=-/usr/bin/docker stop --time 20 opensurveillancedb-ui

[Install]
WantedBy=multi-user.target
